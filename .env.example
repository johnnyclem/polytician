# =============================================================================
# Politician MCP Server - Environment Variables
# =============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Node environment (development | production)
NODE_ENV=development

# Logging level (debug | info | warn | error)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Python Sidecar Configuration
# -----------------------------------------------------------------------------

# Host for the Python sidecar (default: 127.0.0.1)
# WARNING: Never expose to external network in production
SIDECAR_HOST=127.0.0.1

# Port for the Python sidecar (default: 8787)
SIDECAR_PORT=8787

# Timeout for sidecar requests in milliseconds (default: 120000)
SIDECAR_TIMEOUT=120000

# Maximum retries for sidecar requests (default: 3)
SIDECAR_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# Path to SQLite database file
# Use absolute path in production
DB_PATH=./data/concepts.db

# -----------------------------------------------------------------------------
# ML Model Configuration
# -----------------------------------------------------------------------------

# Sentence transformer model for embeddings
# Options: all-MiniLM-L6-v2 (fast), all-mpnet-base-v2 (accurate)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector dimension (must match embedding model)
# all-MiniLM-L6-v2: 768
# all-mpnet-base-v2: 768
VECTOR_DIMENSION=768

# spaCy model for NER
# Options: en_core_web_sm (fast), en_core_web_md (balanced), en_core_web_lg (accurate)
SPACY_MODEL=en_core_web_sm

# -----------------------------------------------------------------------------
# FAISS Configuration
# -----------------------------------------------------------------------------

# Path to FAISS index file
FAISS_INDEX_PATH=./data/faiss.index

# Path to ID mapping file
FAISS_ID_MAP_PATH=./data/id_map.json

# Number of neighbors to return in similarity search (default: 5)
FAISS_DEFAULT_K=5
